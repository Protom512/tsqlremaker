{
  "name": "ase-ls",
  "displayName": "SAP ASE T-SQL Language Server",
  "description": "Language Server for SAP ASE (Sybase) T-SQL — diagnostics, completion, hover, go-to-definition, references, rename, semantic highlighting, formatting, folding, code actions, and signature help.",
  "version": "0.1.0",
  "publisher": "tsqlremaker",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Protom512/tsqlremaker"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "sql",
    "tsql",
    "sybase",
    "ase",
    "sap",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "extensions": [
          ".sql"
        ],
        "aliases": [
          "SQL",
          "T-SQL",
          "SAP ASE T-SQL"
        ]
      }
    ],
    "configuration": {
      "title": "SAP ASE Language Server",
      "properties": {
        "ase-ls.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the ase-ls binary. If empty, the extension looks for 'ase-ls' on PATH."
        },
        "ase-ls.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Log level for the language server."
        },
        "ase-ls.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
